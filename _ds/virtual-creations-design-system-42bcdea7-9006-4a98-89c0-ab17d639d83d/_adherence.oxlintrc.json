{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/media/**",
              "components/navigation/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Unbounded|Space Grotesk|Space Mono))/i]",
        "message": "Font not provided by the design system. Available: Unbounded, Space Grotesk, Space Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|size|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cyan|unity|unreal|vr|ar|ai|magenta|violet|lime|amber)$/]",
        "message": "<Badge> tone must be one of 'cyan' | 'unity' | 'unreal' | 'vr' | 'ar' | 'ai' | 'magenta' | 'violet' | 'lime' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|full|disabled|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, full, disabled, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|aurora|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'aurora' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|glow|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, glow, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|placeholder|type|textarea|value|name|onChange|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, placeholder, type, textarea, value, name, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|key|ref|className|style|children)$/]",
        "message": "<FilterTabs> doesn't accept that prop. Declared props: tabs, active, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|blurb|engine|medium|image|initials|accent|onOpen|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: title, blurb, engine, medium, image, initials, accent, onOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute[name.name='engine'] > Literal[value!=/^(?:Unity|Unreal)$/]",
        "message": "<ProjectCard> engine must be one of 'Unity' | 'Unreal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:cyan|magenta|violet|lime|amber)$/]",
        "message": "<ProjectCard> accent must be one of 'cyan' | 'magenta' | 'violet' | 'lime' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dot|tone|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, dot, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:cyan|magenta|violet|lime|amber)$/]",
        "message": "<Tag> tone must be one of 'cyan' | 'magenta' | 'violet' | 'lime' | 'amber'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
